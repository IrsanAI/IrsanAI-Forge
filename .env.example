# IrsanAI Forge environment template
# Full onboarding docs: README.md -> "OAuth Setup (GitHub)" and "Vercel Deploy"
# Copy to .env.local for local dev: cp .env.example .env.local

# --- App URLs ---
NEXTAUTH_URL=http://localhost:3000

# --- Secrets (required) ---
# Generate with one of:
# 1) openssl rand -base64 32
# 2) node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=replace_with_a_secure_random_secret
AUTH_SECRET=replace_with_a_secure_random_secret

# --- GitHub OAuth App (required for repo sync) ---
# Create at: https://github.com/settings/developers
# Authorization callback URL (local): http://localhost:3000/api/auth/callback/github
GITHUB_ID=your_github_oauth_client_id
GITHUB_SECRET=your_github_oauth_client_secret

# --- Optional ---
NEXT_TELEMETRY_DISABLED=1
